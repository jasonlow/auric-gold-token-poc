{
  "name": "auric-smart-contract",
  "version": "0.1.0",
  "private": true,
  "description": "Auric ERC-3643 gold token suite (XAU.g) — Hardhat",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:amoy": "hardhat run scripts/deploy-amoy.ts --network amoy",
    "verify:amoy": "hardhat run scripts/verify-amoy.ts --network amoy",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "export": "hardhat run scripts/export-artifacts.ts",
    "estimate-gas": "hardhat run scripts/estimate-gas.ts",
    "set-price": "hardhat run scripts/set-price.ts --network amoy",
    "new-wallet": "ts-node scripts/new-wallet.ts",
    "check-amoy": "ts-node scripts/check-amoy.ts",
    "fund-minter": "ts-node scripts/fund-minter.ts",
    "slither": "./.venv-slither/bin/slither . --filter-paths node_modules"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
