# Auric — root environment template
# ---------------------------------------------------------------------------
# Usage:   cp .env.example .env   then fill in the BLANK values.
# The real `.env` is git-ignored. NEVER commit real keys, PII, or mainnet keys.
# Everything here is for LOCAL DEV + the POLYGON AMOY TESTNET ONLY.
# ===========================================================================

# ---- Database (used by docker-compose + token-engine) ----
DB_USER=auric
DB_PASS=auric_local_dev          # local dev only; not a secret
DB_NAME=auric
DB_PORT=5432

# ---- Service ports (host side) ----
API_PORT=8080
SIM_PORT=9090
ADMINER_PORT=8081
WEB_INVESTOR_PORT=5173
WEB_ADMIN_PORT=5174

# ---- Token Engine (Spring Boot) ----
SPRING_PROFILES=local,mock        # `mock` wires the simulated vendors; swap to real later
JWT_SECRET=                       # fill with a long random string (sign-in / portal auth)
VENDOR_SIM_BASE_URL=http://vendor-simulator:9090

# ---- Blockchain (Polygon Amoy testnet) ----
BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology   # or your Alchemy Amoy URL
BLOCKCHAIN_CHAIN_ID=80002
# Engine minter key — the ONLY address allowed to mint/burn (TrustedIssuers).
# TEST KEY ONLY. Funded with faucet MATIC. Set in INFRA-04.
MINTER_PRIVATE_KEY=

# ---- Deployed contract addresses (fill after CONTRACT-06 deploy) ----
GOLD_TOKEN_ADDRESS=
IDENTITY_REGISTRY_ADDRESS=
COMPLIANCE_MODULE_ADDRESS=
TRUSTED_ISSUERS_ADDRESS=
PRICE_FEED_ADDRESS=               # Chainlink MockV3Aggregator (XAU/USD)

# ---- Web (Vite) — only VITE_* vars are exposed to the browser ----
VITE_API_BASE_URL=http://localhost:8080
VITE_CHAIN_ID=80002

# ===========================================================================
# Secrets convention
# - Root `.env`            → docker-compose + token-engine runtime
# - auric-smart-contract/.env → Hardhat (deployer key, PolygonScan API key)
# - auric-web/.env         → Vite VITE_* values
# Keep secrets out of code and YAML. Test keys only. Rotate if ever exposed.
# ===========================================================================
