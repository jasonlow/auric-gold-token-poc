# auric-web — Vite environment template
# cp .env.example .env  (real .env is git-ignored).
# Only VITE_* variables are exposed to the browser — never put secrets here.

VITE_API_BASE_URL=http://localhost:8080

# Polygon Amoy testnet
VITE_CHAIN_ID=80002
VITE_CHAIN_NAME=Polygon Amoy
VITE_RPC_URL=https://rpc-amoy.polygon.technology
VITE_BLOCK_EXPLORER_URL=https://amoy.polygonscan.com

# Filled after contracts are deployed (addresses from deployments/amoy.json)
VITE_GOLD_TOKEN_ADDRESS=
VITE_IDENTITY_REGISTRY_ADDRESS=
