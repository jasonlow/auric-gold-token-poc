# auric-smart-contract — Hardhat environment template
# cp .env.example .env  (real .env is git-ignored). TEST KEYS / TESTNET ONLY.

# Polygon Amoy testnet
AMOY_RPC_URL=https://rpc-amoy.polygon.technology   # or your Alchemy Amoy URL
CHAIN_ID=80002

# Deployer account — deploys contracts to Amoy. TEST KEY ONLY, funded via faucet (INFRA-04).
DEPLOYER_PRIVATE_KEY=

# Minter address that will be set as the TrustedIssuer (the Token Engine's MINTER_PRIVATE_KEY address).
MINTER_ADDRESS=

# PolygonScan (Amoy) API key — for contract verification (optional but recommended)
POLYGONSCAN_API_KEY=

# Deployed MockV3Aggregator (XAU/USD) — filled after deploy (CONTRACT-06); used by set-price
PRICE_FEED_ADDRESS=
# Optional: price to set when running `npm run set-price` (USD per troy ounce)
PRICE_USD_OZ=2400
